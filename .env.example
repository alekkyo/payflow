# ── Local development ─────────────────────────────────────────────────────────
# Copy to .env and fill in values.
# DATABASE_URL and REDIS_URL are overridden by docker-compose.prod.yml in
# production, so only the Stripe + app vars need to be changed there.

DATABASE_URL=postgres://payflow:payflow@localhost:5432/payflow?sslmode=disable
REDIS_URL=redis://localhost:6379
PORT=8080
ENV=development

# Stripe (test mode — get from https://dashboard.stripe.com/test/apikeys)
STRIPE_API_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# CORS — comma-separated list of allowed origins
# Dev default: Vite dev server. Production: your public domain.
ALLOWED_ORIGINS=http://localhost:5173

# Optional: set to introduce an artificial delay before saga workers process events.
# Useful to observe SSE transitions in slow motion during a demo.
# WORKER_DELAY=3s

# Optional: OpenTelemetry collector endpoint (e.g. Jaeger)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Production-only additions (add to server .env) ────────────────────────────
# DB_USER=payflow
# DB_PASSWORD=<strong-random-password>
# ALLOWED_ORIGINS=https://payflow.alexkua.com
# ENV=production
